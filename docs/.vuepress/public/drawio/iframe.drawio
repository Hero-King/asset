                </mxCell>
                <mxCell id="65" value="iframe通信&amp;nbsp;&lt;br&gt;&lt;div&gt;API:&amp;nbsp;&amp;nbsp;&lt;span style=&quot;background-color: initial;&quot;&gt;window.addEventListener(&quot;message&quot;, receiveMessage, false);&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;event 对象的主要属性：&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;&amp;nbsp;data：从其他窗口发送过来的数据&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;&amp;nbsp;origin：发送消息的窗口的源&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;&amp;nbsp;source：发送消息的窗口对象的引用&lt;/span&gt;&lt;/div&gt;&lt;span style=&quot;background-color: rgb(28, 29, 33); font-size: 12px; font-family: &amp;quot;JetBranins Mono&amp;quot;, Monaco, Consolas, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(192, 197, 206);&quot;&gt;&lt;br&gt;&lt;/span&gt;" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#666600;rounded=0;align=left;" vertex="1" parent="1">
